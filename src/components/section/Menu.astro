---
import { Image } from 'astro:assets';
import { content } from '../../config/content';

const { title, items } = content.menu;
---
<section class="section menu" id="menu">
  <div class="inner menu-inner">
    <header class="section-title">
      <h2 class="title">{ title }</h2>
    </header>
    <ul class="list">
      {items.map((item, index) => (
        <li class="item" style={`z-index: ${index + 1}`}>
          <span class="number" aria-hidden="true">{ String(index + 1).padStart(2, "0") }</span>
          <div class="img-wrap">
            <Image class="image" src={ item.image } alt={ item.name } />
          </div>
          <div class="body">
            <h3 class="name">{ item.name }</h3>
            {item.price && <p class="price">{ item. price }</p>}
            {item.description && <p class="description">{ item.description }</p>}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  // ―――――――――――――――――――――――――――――――――――
  .section-title {
    position: relative;
    z-index: 20;
  }

  // スタッキング用カード（GSAP ScrollTrigger でピン留めされる）
  .item {
    position: relative;
    display: grid;
    align-content: center;
    min-height: 100vh;
    padding: 60px 0;
    background-color: $bg-base;
  }

  .number {
    position: absolute;
    top: clamp(24px, 8vh, 90px);
    left: clamp(0px, 1vw, 12px);
    z-index: 0;
    font-family: "Jockey One", sans-serif;
    font-size: clamp(4rem, 14vw, 11rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: rgba(151, 132, 93, 0.22);
    pointer-events: none;
    user-select: none;
  }

  .img-wrap,
  .body {
    position: relative;
    z-index: 1;
    grid-area: 1 / 1;
  }

  .img-wrap {
    justify-self: end;
    width: clamp(200px, 55vw, 900px);
  }

  .image {
    display: block;
  }

  .body {
    align-self: end;
    padding: 40px 16px 0;
  }

  .name {
    font-weight: 500;
  }

  .price,
  .description {
    display: block;
    width: fit-content;
    background-color: rgba(247, 245, 234, 0.6);
  }

  .description {
    margin-top: 16px;
  }

  @include pc {
    .img-wrap {
      /* justify-self: center;  画像を中央配置にしたい場合 */
    }
  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / タブレット
  @include tb {

  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / スマホ
  @include sp {
    .body {
      padding-top: 160px;
    }
  }
</style>