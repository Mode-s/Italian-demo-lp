---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

const { shop, sns } = siteConfig;

const snsLinks = [
  { label: "X",         href: sns.x,         icon: "simple-icons:x" },
  { label: "Instagram", href: sns.instagram, icon: "simple-icons:instagram", slug: "instagram" },
  { label: "LINE",      href: sns.line,      icon: "simple-icons:line",      slug: "line" },
  { label: "Facebook",  href: sns.facebook,  icon: "simple-icons:facebook" },
  { label: "食べログ",   href: sns.tabelog,   icon: "simple-icons:tabelog",   slug:"tabelog" },
].filter(( item ) => item.href );
---
<section class="section contact" id="contact">
  <div class="inner contact-inner">
    <header class="section-title">
      <h2 class="title">CONTACT</h2>
    </header>
    <p class="text">お問い合わせ・ご予約は、<br />下記電話または各SNSまでお願いします。</p>
    <div class="actions">
      { shop.tel.display && (
        <a class="tel" href={`tel:${ shop.tel.link }`}>
          <Icon class="contact-tel-icon" name="mdi:phone" />
          <p class="tel-label" >{ shop.tel.display }</p>
        </a>
      )}
      { snsLinks.length > 0 && (
        <ul class="sns-list">
          { snsLinks.map(( item ) => (
            <li class="sns-item">
              <a class={`sns-link sns-link--${item.slug}`} href={ item.href } target="_blank" rel="noopener noreferrer">
                <Icon class="sns-icon" name={item.icon} />
                <p class="sns-label">{item.label}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .text {
    text-align: center;
    margin-top: 56px;
    font-size: clamp(0.7rem, 5vw, 0.9rem);
  }

  // ―――――――――――――――――――――――――――――――――――
  .actions {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    margin: 0 auto;
  }

  .sns-list {
    display: inline-flex;
    justify-content: center;
    gap: 48px;
    margin-top: 56px;
  }

  .tel,
  .sns-link {
    display: inline-flex;
    align-items: center;
  }

  .tel {
    justify-content: center;
    max-width: 300px;
    width: 100%;
    gap: 8px;
    margin: 56px auto 0;
    padding: 10px 40px;
    border-radius: 50px;
    background-color: #70a86f;
    color: #fff;
    font-weight: 500;
  }

  .contact-tel-icon,
  .sns-icon {
    display: block;
    flex-shrink: 0;
    width: 1.25em;
    height: 1.25em;
  }

  .sns-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    color: inherit;
  }

  .sns-icon {
    display: block;
    flex-shrink: 0;
  }

  .sns-label {
    font-size: clamp(0.6rem, 5vw, 0.9rem);
  }

  .sns-link--x {
    color: #000000;
  }
  .sns-link--instagram {
    color: #e4405f;
  }
  .sns-link--line {
    color: #06c755;
  }
  .sns-link--tabelog {
    color: #f59600;
  }

  .sns-link--instagram .sns-label {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / タブレット
  @include tb {

  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / スマホ
  @include sp {

  }
</style>