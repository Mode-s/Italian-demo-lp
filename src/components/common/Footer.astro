---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

import { siteConfig } from '../../config/site';
import { content } from '../../config/content';

const { logo } = content.header;

---
<footer class="footer">
  <div class="inner footer-inner">
    <a class="logo-link" href={logo.href}>
      <Image class="logo-img" src={logo.src} alt={logo.alt} />
    </a>
    <div class="shop-wrap">
      <p class="name">{siteConfig.name}</p>
      <address class="address">{siteConfig.shop.address}</address>
      <p class="open">{siteConfig.shop.hours}</p>
    </div>
    <div class="sns-wrap">

    </div>
  </div>
  <small class="copyright">
    &copy; 2026 {siteConfig.name} 
  </small>
</footer>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .footer {
    color: $bg-base;
    padding-top: clamp(80px, 12vw, 140px);
    background: linear-gradient(
      to bottom,
      $bg-base 0px,
      #e8decb 40px,
      #d4c5a8 80px,
      #b9a57d 120px,
      $footer-bg 190px,
      $footer-bg 100%
    );
  }

  .footer-inner {
    padding: 20px;
  }

  .logo-link {
    max-width: 400px;
    max-height: 400px;
    margin: 0 auto;
  }

  .shop-wrap {
    max-width: 400px;
    margin: 8px auto 0;
  }

  // ―――――――――――――――――――――――――――――――――――
  .copyright {
    display: block;
    text-align: center;
    padding: 5px;
  }

  //―――――――――――――――――――――――――――――――――――――― タブレット
  @include tb {

  }

  //―――――――――――――――――――――――――――――――――――――― スマホ
  @include sp {

  }
</style>