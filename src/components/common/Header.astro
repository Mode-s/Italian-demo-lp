---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { content } from '../../config/content';

const { logo, nav } = content.header;
---
<header class="header">
  <div class="inner header-inner">
    <h1 class="header-logo">
      <a class="logo-link" href={logo.href}>
        <Image class="logo-img" src={logo.src} alt={logo.alt} />
      </a>
    </h1>
    <nav class="nav">
      <ul class="nav-list">
        {nav.map((item) => (
          <li class="nav-item">
            <a class="nav-link" href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  // ―――――――――――――――――――――――――――――――――――
  .header {

  }
  // ―――――――――――――――――――――――――――――――――――
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    padding: 20px 40px 20px 20px;
  }

  .header-logo {
    max-width: 100px;
    max-height: 100px;
  }

  .nav-list {
    display: flex;
    gap: 40px;
    letter-spacing: 0.1em;

  }
  //―――――――――――――――――――――――――――――――――――――― タブレット
  @include tb {
    .nav-list {
      display: none;
    }
  }

  //―――――――――――――――――――――――――――――――――――――― スマホ
  @include sp {

  }
</style>